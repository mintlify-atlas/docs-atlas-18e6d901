  "keyFeatures": [
    "Multi-chain support for Polkadot, Substrate, and Ethereum ecosystems",
    "Comprehensive account management with import/export capabilities",
    "NFT viewing and management across multiple chains",
    "Staking with APY tracking and multiple validators",
    "Cross-chain token swaps and transfers",
    "WalletConnect integration for dApp connectivity",
    "MetaMask compatibility layer",
    "Ledger hardware wallet support",
    "Advanced phishing detection",
    "Multisig and proxy account support"
  ],
  "publicApiSurface": [
    "web3Enable() - Enable dApp to access wallet",
    "web3Accounts() - Get user accounts",
    "web3FromAddress() - Get signer for address",
    "web3FromSource() - Get signer from source",
    "web3ListRpcProviders() - List RPC providers",
    "web3UseRpcProvider() - Use specific RPC provider",
    "@subwallet/extension-base - Core extension functionality",
    "@subwallet/extension-dapp - DApp integration wrapper",
    "@subwallet/extension-inject - Injection convenience wrapper",
    "@subwallet/extension-chains - Chain definitions",
    "Message passing API for background-UI communication",
    "Storage API for persisting extension state",
    "Service APIs (Balance, NFT, Earning, Transaction, Chain)",
    "Keyring service for account management",
    "WalletConnect integration API"
  ]
